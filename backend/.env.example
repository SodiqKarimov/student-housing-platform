# =============================================
# TALABALAR TURAR JOYI BOSHQARUV TIZIMI
# O'zbekiston davlat standartlariga muvofiq
# =============================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Ma'lumotlar bazasi (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/student_housing_db"

# JWT (JSON Web Token)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# OneID (E-hukumat yagona identifikatsiya tizimi)
# Ro'yxatdan o'tish: https://id.egov.uz
ONEID_CLIENT_ID=your_oneid_client_id
ONEID_CLIENT_SECRET=your_oneid_client_secret
ONEID_REDIRECT_URI=http://localhost:5000/api/v1/auth/oneid/callback
ONEID_AUTH_URL=https://sso.egov.uz/sso/oauth/Authorization.do
ONEID_TOKEN_URL=https://sso.egov.uz/sso/oauth/Authorization.do
ONEID_USER_INFO_URL=https://sso.egov.uz/sso/oauth/Authorization.do

# HEMIS (Oliy ta'lim axborot boshqaruv tizimi)
# Ro'yxatdan o'tish: https://hemis.uz
HEMIS_API_URL=https://student.hemis.uz/rest/v1
HEMIS_API_KEY=your_hemis_api_key
HEMIS_UNIVERSITY_ID=your_university_id

# SMS xizmati (Eskiz.uz)
SMS_PROVIDER=eskiz
SMS_EMAIL=your_email@university.uz
SMS_SECRET=your_sms_api_secret
SMS_SENDER_NAME=HousingUz

# Telegram Bot
# BotFather dan oling: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Guruh yoki kanal chat ID (bildirishnomalar uchun)
TELEGRAM_CHAT_ID=your_group_chat_id
TELEGRAM_ADMIN_CHAT_ID=your_admin_personal_chat_id

# Redis (ixtiyoriy — yo'q bo'lsa in-memory cache ishlatiladi)
REDIS_URL=redis://localhost:6379

# Fayl yuklash
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Shifrlash (O'RQ-547 - Shaxsiy ma'lumotlar)
ENCRYPTION_KEY=your_exactly_32_character_key_here
ENCRYPTION_IV=your_16char_iv_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://housing.university.uz

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Audit log saqlash muddati (kun)
AUDIT_LOG_RETENTION_DAYS=365
